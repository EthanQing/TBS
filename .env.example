MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_HOST=localhost
MYSQL_DATABASE=train_backend_v2
MYSQL_PORT=3306

# Optional (overrides MYSQL_*):
# DATABASE_URL=sqlite+pysqlite:///./train_backend_v2.db
# ALEMBIC_DATABASE_URL=sqlite+pysqlite:///./train_backend_v2.db

BACKEND_PORT=18000

# Worker tuning (optional)
WORKER_POLL_INTERVAL=2
WORKER_HEARTBEAT_INTERVAL=5
WORKER_STALE_AFTER_SECONDS=120

# Storage paths (optional)
# BASE_DATASETS_DIR=/path/to/datasets
# BASE_TRAINING_DIR=/path/to/training_runs
# BASE_TEMP_DIR=/path/to/temp
# BASE_PRETRAIN_MODELS_DIR=/path/to/pretrain_models

# MLflow tracking (optional)
# MLFLOW_ENABLE=true
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_EXPERIMENT_NAME=TrainPlatform

# Software usage limit (optional)
# Allowed start time, ISO8601. Example: 2026-04-03T00:00:00+08:00
# SOFTWARE_NOT_BEFORE_AT=
# Allowed end time, ISO8601. Example: 2026-05-15T23:59:59+08:00
# SOFTWARE_NOT_AFTER_AT=
# Legacy alias of SOFTWARE_NOT_AFTER_AT
# SOFTWARE_EXPIRES_AT=
# Allowable backward clock skew in seconds before treating it as tampering
# SOFTWARE_CLOCK_ROLLBACK_TOLERANCE_SECONDS=300
