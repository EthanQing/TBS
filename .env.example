MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_HOST=localhost
MYSQL_DATABASE=train_backend_v2
MYSQL_PORT=3306

# Optional (overrides MYSQL_*):
# DATABASE_URL=sqlite+pysqlite:///./train_backend_v2.db
# ALEMBIC_DATABASE_URL=sqlite+pysqlite:///./train_backend_v2.db

BACKEND_PORT=18000

# Worker tuning (optional)
WORKER_POLL_INTERVAL=2
WORKER_HEARTBEAT_INTERVAL=5
WORKER_STALE_AFTER_SECONDS=120

# MLflow tracking (optional)
# MLFLOW_ENABLE=true
# MLFLOW_TRACKING_URI=file:./mlruns
# MLFLOW_EXPERIMENT_NAME=TrainPlatform
